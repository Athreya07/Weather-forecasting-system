# Pune Weather Forecasting System — Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=pune_weather
DATABASE_URL=postgresql://postgres:changeme_secure_password@db:5432/pune_weather

# ── Application ───────────────────────────────────────────────────
MODEL_PATH=./ml/models
DATA_PATH=./data
LOG_LEVEL=INFO
DEBUG=false

# ── AWS (optional, for deployment) ────────────────────────────────
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
